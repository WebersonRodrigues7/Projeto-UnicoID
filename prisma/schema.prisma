generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

enum Role {
  LEAD
  CLIENT
}

model User { 
  id Int @id @default(autoincrement()) 
  email String @unique
  password String 

}

model Customer {
  id Int @id @default(autoincrement())
  name String
  lastName String
  role Role @default(CLIENT)


}